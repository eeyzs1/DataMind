{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Config File",
  "type": "object",
  "required": [
    "version",
    "type"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "type": {
      "type": "string"
    },
    "description": {
      "type": "string"
    }
  }
}